.git
node_modules
.pnpm-store
# Include lockfile for builds
!pnpm-lock.yaml
# Ignore local env files
.env
.env.*
apps/*/.env
apps/*/.env.*
packages/*/.env
packages/*/.env.*
# Ignore build outputs
dist
build
.next
out
apps/*/dist
apps/*/build
packages/*/dist
packages/*/build

# Scratch, Testing, and Temporary Files
scratch/
**/scratch/
tmp/
temp/
test-results/
playwright-report/
blob-report/
*.sql
**/*.sql
*.md
**/*.md
plan-*.md
plan_*.md
screenshot-*.md
video_recording_plan.md
task-*.md
task_*.md
!README.md
!README.md.resolved
docs/
.agents/
plans/

# Debug and unneeded scripts
test*.js
test*.ts
test*.cjs
check*.js
check*.ts
check*.cjs
debug_*.js
debug_*.ts
scratch.ts
scratch_*.js
fix_*.js

# Allow real application jobs that start with test or check
!apps/worker/src/jobs/test*.ts
!apps/worker/src/jobs/check*.ts
*_dump.html
*dump.html
google.html
basecamp_*.png
basecamp_*.json
cloudbuild.recording.yaml
